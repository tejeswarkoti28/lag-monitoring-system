# Secrets — never bake env files into the image
.env
.env.*
.env.local

# Local SQLite databases — runtime artifacts, not code
*.db
*.db-shm
*.db-wal
*.db-journal

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Git / IDE / OS
.git/
.gitignore
.idea/
.vscode/
.DS_Store
Thumbs.db

# Local scratchpad
outputs/

# Docs and tests don't need to be in the production image
README.md
CLAUDE.md
e2e_test.py
