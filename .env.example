# =============================================================================
# Kafka Lag Monitor — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in real values. python-dotenv loads .env
# automatically on startup; never commit `.env` (already in .gitignore).
# =============================================================================
#
# Data source connection details (URL, auth, static labels) are NOT here —
# they live in config/data_sources.json which IS committed. Only secrets and
# environment-specific runtime tweaks belong here.


# --- AI chatbot (Gemini) ----------------------------------------------------
# Get a free key at https://ai.google.dev. Without a key the dashboard still
# works — the AI button is greyed out.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash


# --- Grafana session cookie (corporate SSO bypass) -------------------------
# If your Grafana sits behind SSO and queries fail with a 302 redirect to
# the company login, copy your browser's `grafana_session` cookie value
# here. Lasts until the browser session expires (typically hours/days).
# Format: GRAFANA_COOKIE=grafana_session=eyJhbGciOiJIUz...
GRAFANA_COOKIE=


# --- Alert threshold --------------------------------------------------------
# Per-message lag threshold for breach detection. Tune to your cluster's
# noise floor. Override config/jobs.json's value without editing JSON.
LAG_THRESHOLD=5000


# --- Slack webhook routing --------------------------------------------------
# Per-team webhook URLs. If a per-team variable is set, alerts for that team
# go there. Otherwise SLACK_WEBHOOK_URL is the fallback. If neither is set,
# alerts are in-app/DB only.
SLACK_WEBHOOK_URL=
SLACK_WEBHOOK_PNO_TEAM=
SLACK_WEBHOOK_CATALOG_TEAM=
SLACK_WEBHOOK_SHIPPING_TEAM=


# --- Slack on-call mention tags ---------------------------------------------
# Prepended to the Slack message so the right people get pinged.
#   user-group:    <!subteam^S0123ABCD|@pno-oncall>
#   channel-wide:  <!channel>     (default if unset)
#   active-only:   <!here>
SLACK_ONCALL_PNO=
SLACK_ONCALL_CATALOG=
SLACK_ONCALL_SHIPPING=


# --- Server (rarely changed) ------------------------------------------------
# HOST=0.0.0.0
# PORT=8000
# LAG_MONITOR_DB=lag_monitor.db
# LAG_MONITOR_PUBLIC_URL=http://localhost:8000
# LAG_MONITOR_CONFIG=./config/jobs.json
# DATA_SOURCES_CONFIG=./config/data_sources.json
# PANELS_CONFIG=./config/panels.json
# POLL_INTERVAL_SECONDS=5

# --- History retention ------------------------------------------------------
# Days of lag_history rows to keep. Cleanup runs at startup.
LAG_HISTORY_RETENTION_DAYS=90
