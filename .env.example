# =============================================================================
# Kafka Lag Monitor — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in real values. python-dotenv loads .env
# automatically on startup; never commit `.env` (already in .gitignore).
# Every variable below is OPTIONAL — the app runs with no .env at all (you
# just lose Slack delivery and the chatbot, and the Lenses data source needs
# its own credentials when DATA_SOURCE=lenses).
# =============================================================================


# --- Data source -------------------------------------------------------------
# simulator   (default) — synthetic data, no creds, runs anywhere
# lenses                — Lenses REST API (production target)
# prometheus            — Prometheus / TSDB (alternative)
DATA_SOURCE=simulator

# When DATA_SOURCE=lenses, set these (pick token OR username+password):
LENSES_URL=
LENSES_API_TOKEN=
LENSES_USERNAME=
LENSES_PASSWORD=
# Override only if your Lenses build uses a non-default endpoint path:
# LENSES_LAG_ENDPOINT_TEMPLATE=/api/v1/kafka/consumers/{group}

# When DATA_SOURCE=prometheus, set these:
PROMETHEUS_URL=
PROMETHEUS_AUTH_TOKEN=


# --- AI chatbot --------------------------------------------------------------
# Default provider is Gemini. Get a free key at https://ai.google.dev.
# Without a key set, the dashboard still works — the AI button is greyed out.
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Alternative: OpenAI. Switch by setting LLM_PROVIDER=openai above.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini


# --- Slack webhook routing ---------------------------------------------------
# Per-team webhook URLs. If a per-team variable is set, alerts for that team
# go there. Otherwise SLACK_WEBHOOK_URL is the fallback. If neither is set,
# alerts are in-app/DB only.
SLACK_WEBHOOK_URL=
SLACK_WEBHOOK_PNO_TEAM=
SLACK_WEBHOOK_CATALOG_TEAM=
SLACK_WEBHOOK_SHIPPING_TEAM=


# --- Slack on-call mention tags ---------------------------------------------
# Prepended to the Slack message so the right people get pinged.
#   user-group:    <!subteam^S0123ABCD|@pno-oncall>
#   channel-wide:  <!channel>     (default if unset)
#   active-only:   <!here>
SLACK_ONCALL_PNO=
SLACK_ONCALL_CATALOG=
SLACK_ONCALL_SHIPPING=


# --- Server ------------------------------------------------------------------
# HOST=0.0.0.0
# PORT=8000
# LAG_MONITOR_DB=lag_monitor.db
# LAG_MONITOR_PUBLIC_URL=http://localhost:8000
# LAG_MONITOR_CONFIG=./config/jobs.json
# POLL_INTERVAL_SECONDS=5

# --- History retention -------------------------------------------------------
# Days of lag_history rows to keep. Cleanup runs at startup.
# 90 days = ~2.7 GB on disk for 18 jobs at 5-second polling.
LAG_HISTORY_RETENTION_DAYS=90
