# =============================================================================
# Kafka Lag Monitor — full environment variable reference
# =============================================================================
# Copy this to .env and fill in values. Only uncommented lines in .env
# are required. Everything else has a sensible default.
#
# SLACK ROUTING CONVENTION:
#   Each job in jobs.json has a "team" field.
#   "Team"         → SLACK_WEBHOOK_TEAM
#   "Catalog Team" → SLACK_WEBHOOK_CATALOG_TEAM
#   To add a new team: add the job in jobs.json, set the env var below.
#   SLACK_WEBHOOK_URL is the fallback if no team-specific var is found.
# =============================================================================

# AI chatbot — get a free key at https://ai.google.dev
GEMINI_API_KEY = your-gemini-api-key-here
# GEMINI_MODEL = gemini-2.5-flash

# Slack — one line per team in jobs.json
SLACK_WEBHOOK_TEAM = https://hooks.slack.com/services/...
# SLACK_ONCALL_TEAM = <!here>
# SLACK_WEBHOOK_URL = https://hooks.slack.com/services/...   (fallback)

# Grafana session cookie — DevTools → Application → Cookies → grafana_session
# GRAFANA_COOKIE = your-grafana-session-cookie

# Deployment
# LAG_MONITOR_PUBLIC_URL = http://10.238.161.135:8000
# POLL_INTERVAL_SECONDS  = 5
# LAG_THRESHOLD          = 5000
# HOST                   = 0.0.0.0
# PORT                   = 8000

# Storage
# LAG_MONITOR_DB       = lag_monitor.db
# LAG_HISTORY_RAW_DAYS = 7
# LAG_HISTORY_1M_DAYS  = 90
# LAG_HISTORY_1H_DAYS  = 1095

# Config paths (only if you move files)
# LAG_MONITOR_CONFIG  = config/jobs.json
# DATA_SOURCES_CONFIG = config/data_sources.json
